// INVEST User Story Validator for Azure DevOps
// No AI integration no Gherkin
// Scores each story against Independent, Negotiable, Valuable, Estimable, Small, Testable.

using System.Text.Json;
using System.Text.Json.Serialization;
using System.Text.RegularExpressions;

// ─── Entry Point ──────────────────────────────────────────────────────────────
// Everything executable lives here. Types and methods are below in Validator.

