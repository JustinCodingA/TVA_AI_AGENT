const string token = "CLm1quEeBgJOJWNSRihAJI0b4vfEw1V01ieXMjyUiPCuXmgO5XI3JQQJ99CCACAAAAAAAAAAAAASAZDO1PXo";
const string url   = "https://dev.azure.com/burlaka1140/aggy/_apis/wit/workitems/19?api-version=7.0";

// fetch the work item from Azure DevOps
using var http = new HttpClient();
