@model TvaInvestValidator.Models.ViewModels.WorkItemsListViewModel

@{
    ViewData["Title"] = "Work Items";
}

<div class="mb-4">
    <div class="d-flex justify-content-between align-items-start">
        <div>
            <h1 class="display-6 fw-semibold">Work Items</h1>
            <p class="text-muted">User stories, epics, and features from Azure DevOps</p>
        </div>
        <div class="d-flex gap-2">
            <form asp-action="PullFromAzureDevOps" method="post" class="d-inline">
                <button type="submit" class="btn btn-outline-primary">
                    <i class="fas fa-sync-alt me-2"></i>
                    Pull from Azure DevOps
                </button>
            </form>
            <button class="btn btn-outline-secondary">
                <i class="fas fa-download me-2"></i>
                Export
            </button>
        </div>
    </div>
</div>

<!-- Filters -->
<div class="card shadow-sm mb-4">
    <div class="card-header bg-white">
        <h5 class="card-title mb-0">Filters</h5>
    </div>
    <div class="card-body">
        <form asp-action="Index" method="get">
            <div class="row g-3">
                <div class="col-md-8">
                    <div class="position-relative">
                        <i class="fas fa-search position-absolute top-50 start-0 translate-middle-y ms-3 text-muted"></i>
                        <input type="text" name="searchQuery" value="@Model.SearchQuery"
                               class="form-control ps-5" placeholder="Search by ID or title..." />
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-filter"></i></span>
                        <select name="filterType" class="form-select">
                            <option value="all" selected="@(Model.FilterType == "all")">All Types</option>
                            <option value="UserStory" selected="@(Model.FilterType == "UserStory")">User Story</option>
                            <option value="Epic" selected="@(Model.FilterType == "Epic")">Epic</option>
                            <option value="Feature" selected="@(Model.FilterType == "Feature")">Feature</option>
                        </select>
                        <button type="submit" class="btn btn-primary">Apply</button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Work Items Table -->
<div class="card shadow-sm">
    <div class="card-header bg-white">
        <h5 class="card-title mb-1">Work Items (@Model.FilteredItems.Count)</h5>
        <p class="text-muted mb-0 small">Showing @Model.FilteredItems.Count of @Model.WorkItems.Count items</p>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Type</th>
                        <th>Title</th>
                        <th>Status</th>
                        <th>INVEST</th>
                        <th>Assigned To</th>
                        <th>Priority</th>
                        <th>Last Updated</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.FilteredItems)
                    {
                        <tr>
                            <td class="font-monospace">@item.Id</td>
                            <td><span class="badge bg-secondary">@item.Type</span></td>
                            <td style="max-width: 300px;">@item.Title</td>
                            <td>
                                @{
                                    var statusClass = item.Status switch {
                                        WorkItemStatus.Active => "primary",
                                        WorkItemStatus.New => "secondary",
                                        WorkItemStatus.Resolved => "success",
                                        _ => "secondary"
                                    };
                                }
                                <span class="badge bg-@statusClass">@item.Status</span>
                            </td>
                            <td>
                                @if (item.InvestStatusValue != null)
                                {
                                    var investClass = item.InvestStatusValue switch {
                                        InvestStatus.Passed => "success",
                                        InvestStatus.Failed => "danger",
                                        _ => "warning"
                                    };
                                    <span class="badge bg-@investClass">@item.InvestStatusValue</span>
                                }
                            </td>
                            <td>@item.AssignedTo</td>
                            <td>@item.Priority</td>
                            <td>@item.LastUpdated.ToString("yyyy-MM-dd")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="text-center mt-4">
    <a asp-action="Create" class="btn btn-lg btn-primary">
        <i class="fas fa-plus me-2"></i>
        Create New Work Item
    </a>
</div>
